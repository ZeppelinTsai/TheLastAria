	"zh_TW": {
		"sunken_city.lyra_room_entry_surface_hint.001.lumi.text": "Lyra。\n海上好像有東西。",
		"sunken_city.lyra_room_entry_surface_hint.002.lumi.text": "我們去看看。",
		"sunken_city.orion_found_on_surface.001.lumi.text": "……",
		"sunken_city.orion_found_on_surface.002.lumi.text": "是人。",
		"sunken_city.orion_found_on_surface.003.stagedir.text": "［停頓］",
		"sunken_city.orion_found_on_surface.004.lumi.text": "可是……",
		"sunken_city.orion_found_on_surface.005.lumi.text": "人不是故事裡才有嗎？",
		"sunken_city.orion_found_on_surface.006.stagedir.text": "［Lyra 沒說話］",
		"sunken_city.orion_found_on_surface.007.lumi.text": "他還活著。",
		"sunken_city.orion_found_on_surface.008.lumi.text": "像快熄掉的燈。",
		"sunken_city.orion_found_on_surface.009.lumi.text": "……Lyra。",
		"sunken_city.orion_found_on_surface.010.lumi.text": "怎麼辦？",
		"sunken_city.orion_found_on_surface.010.lumi.choices.001.bring_back.text": "帶回去",
		"sunken_city.orion_found_on_surface.010.lumi.choices.002.observe_more.text": "再觀察一下",
		"sunken_city.orion_found_on_surface.010.lumi.choices.002.observe_more.response.001.stagedir.text": "［Lyra 靠近］",
		"sunken_city.orion_found_on_surface.010.lumi.choices.002.observe_more.response.002.stagedir.text": "［海浪翻動 Orion 的手］",
		"sunken_city.orion_found_on_surface.010.lumi.choices.002.observe_more.response.003.lumi.text": "……",
		"sunken_city.orion_found_on_surface.010.lumi.choices.002.observe_more.response.004.lumi.text": "他會沉下去的。",
		"sunken_city.orion_found_on_surface.010.lumi.choices.002.observe_more.response.004.lumi.choices.001.bring_back_after_observe.text": "帶回去",
		"sunken_city.orion_found_on_surface.011.lumi.text": "最近的安全帶……",
		"sunken_city.orion_found_on_surface.012.lumi.text": "那邊。",
		"sunken_city.orion_found_on_surface.013.stagedir.text": "［遠方燈塔島亮一下］",
		"sunken_city.orion_found_on_surface.014.lumi.text": "先不要讓他死掉。",
		"sunken_city.orion_found_on_surface.015.lumi.text": "剩下的。\n之後再想。",
		"sunken_city.orion_found_on_surface.016.stagedir.text": "【轉場】",
		"sunken_city.orion_found_on_surface.017.stagedir.text": "黑畫面。\n切燈塔島。"
	},
